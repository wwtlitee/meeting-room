    "spriteActions": {
      "id": "spriteActions",
      "labelZh": "坐姿与发言动作条矩阵",
      "purpose": "按五体型与八类坐姿/发言动作排列动作条，作为会议专家动画资产的主要生产检查区。",
      "status": "blocked-by-seed-approval",
      "boardRect": {
        "x": 720,
        "y": 880,
        "width": 1120,
        "height": 620
